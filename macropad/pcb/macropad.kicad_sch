  ; ----------------------------------------------------------------
  ; ROTARY ENCODER (ENC1)
  ; ----------------------------------------------------------------
  (symbol (lib_id "Device:Rotary_Encoder_Switch") (at 100 20 0) (unit 1)
    (property "Reference" "ENC1") (property "Value" "EC11")
    (property "Footprint" "Rotary_Encoder:RotaryEncoder_Alps_EC11E-Switch_Vertical_H20mm"))

  ; ----------------------------------------------------------------
  ; OLED CONNECTOR (J1) - 4-pin header above keys
  ; ----------------------------------------------------------------
  (symbol (lib_id "Connector:Conn_01x04_Pin") (at 50 5 0) (unit 1)
    (property "Reference" "J1") (property "Value" "OLED_SSD1306")
    (property "Footprint" "Connector_PinHeader_2.54mm:PinHeader_1x04_P2.54mm_Vertical"))

  ; ----------------------------------------------------------------
  ; RESET BUTTON (SW17)
  ; ----------------------------------------------------------------
  (symbol (lib_id "Switch:SW_Push") (at 130 20 0) (unit 1)
    (property "Reference" "SW17") (property "Value" "RESET")
    (property "Footprint" "Button_Switch_THT:SW_SPST_PTS645"))

  ; ----------------------------------------------------------------
  ; NETS / WIRE CONNECTIONS
  ; ----------------------------------------------------------------

  ; ROW0 (GP0) -> anode of D1,D2,D3,D4
  (wire (pts (xy 20 13) (xy 80 13)))   ; ROW0 bus
  (label "ROW0" (at 20 13 0))

  ; ROW1 (GP1) -> anode of D5,D6,D7,D8
  (wire (pts (xy 20 33) (xy 80 33)))
  (label "ROW1" (at 20 33 0))

  ; ROW2 (GP2) -> anode of D9,D10,D11,D12
  (wire (pts (xy 20 53) (xy 80 53)))
  (label "ROW2" (at 20 53 0))

  ; ROW3 (GP3) -> anode of D13,D14,D15,D16
  (wire (pts (xy 20 73) (xy 80 73)))
  (label "ROW3" (at 20 73 0))

  ; COL0 (GP4) -> pin2 of SW1,SW5,SW9,SW13
  (wire (pts (xy 18 20) (xy 18 80)))
  (label "COL0" (at 18 20 0))

  ; COL1 (GP5) -> pin2 of SW2,SW6,SW10,SW14
  (wire (pts (xy 38 20) (xy 38 80)))
  (label "COL1" (at 38 20 0))

  ; COL2 (GP6) -> pin2 of SW3,SW7,SW11,SW15
  (wire (pts (xy 58 20) (xy 58 80)))
  (label "COL2" (at 58 20 0))

  ; COL3 (GP7) -> pin2 of SW4,SW8,SW12,SW16
  (wire (pts (xy 78 20) (xy 78 80)))
  (label "COL3" (at 78 20 0))

  ; Encoder nets
  (label "ENC_CLK" (at 95 18 0))
  (label "ENC_DT"  (at 95 20 0))
  (label "ENC_SW"  (at 95 22 0))
  (label "GND"     (at 95 24 0))
  (label "+3V3"    (at 95 26 0))

  ; OLED connector nets
