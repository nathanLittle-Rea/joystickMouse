  (symbol (lib_id "Switch:SW_Push") (at 20 20 0) (unit 1)
    (property "Reference" "SW1") (property "Value" "MX_Switch")
    (property "Footprint" "MX_Alps_Hybrid:MX-1U-NoLED"))
