  (label "+3V3"    (at 48 3 0))
  (label "I2C_SDA" (at 50 3 0))
  (label "I2C_SCL" (at 52 3 0))

  ; Reset button: RESET_PIN to GND
  (label "RUN"  (at 128 18 0))
  (label "GND"  (at 128 22 0))

