(kicad_sch (version 20230121) (generator eeschema)

  (lib_symbols
    (symbol "Device:R" (pin_numbers (hide)) (pin_names (offset 0))
      (property "Reference" "R" (at 2.032 0 0) (effects (font (size 1.27 1.27)) (justify left)))
      (property "Value" "R" (at 0 0 0) (effects (font (size 1.27 1.27)) (justify left)))
      (symbol "R_0_1" (rectangle (start -1.016 -2.032) (end 1.016 2.032)))
      (symbol "R_1_1"
        (pin passive line (at 0 3.81 270) (length 1.778) (name "~" (effects (font (size 1.27 1.27)))) (number "1" (effects (font (size 1.27 1.27)))))
        (pin passive line (at 0 -3.81 90) (length 1.778) (name "~" (effects (font (size 1.27 1.27)))) (number "2" (effects (font (size 1.27 1.27)))))
      )
    )
  )

  ; ----------------------------------------------------------------
  ; NET DEFINITIONS (used by netlist export)
  ; ----------------------------------------------------------------
  ; ROW nets:   ROW0..ROW3  (GP0-GP3)
  ; COL nets:   COL0..COL3  (GP4-GP7)
  ; ENC_CLK     GP10
  ; ENC_DT      GP11
  ; ENC_SW      GP12
  ; I2C_SDA     GP16
  ; I2C_SCL     GP17
  ; +3V3        Pico 3V3 out (pin 36)
  ; GND         Pico GND
  ; VBUS        Pico VBUS (pin 40) - 5V from USB

  ; ----------------------------------------------------------------
  ; PICO (U1)  - 40-pin footprint
  ; ----------------------------------------------------------------
  (symbol (lib_id "MCU_RaspberryPi:RPi_Pico") (at 120 80 0) (unit 1)
    (property "Reference" "U1" (at 120 55 0))
    (property "Value" "Raspberry_Pi_Pico" (at 120 57 0))
    (property "Footprint" "MyCustLib:RPi_Pico_SMD" (at 0 0 0) (effects (hide)))
  )

  ; ----------------------------------------------------------------
  ; KEY MATRIX  SW1-SW16  +  D1-D16
  ; Layout: 4 rows x 4 cols, 19.05mm spacing
  ; Each switch connects: one terminal -> ROW via diode (anode=ROW, cathode=switch)
  ;                       other terminal -> COL
  ; ----------------------------------------------------------------

